---
import { Separator } from '@/components/ui/separator';
import Faq from '@/components/landing/Faq';
import MotionCta from '@/components/landing/MotionCta';
import ReplacementMap from '@/components/landing/ReplacementMap';
import '../styles/global.css';

const TALLY_URL = '#waitlist';

const stages = [
  { n: '01', name: 'Plan',      outcome: 'Set up one class once, run it weekly.',                                              mechanic: 'Event templates, recurring schedules, venue and speaker conflict detection.' },
  { n: '02', name: 'Market',    outcome: 'Your event page, email list, and waitlist live in the same system.',                 mechanic: 'Per-event landing page with SEO settings, tag-based email blasts, waitlist with auto-notification.' },
  { n: '03', name: 'Sell',      outcome: 'Take bank transfer, QRIS, vouchers, and referral discounts without a spreadsheet.',  mechanic: 'Order lifecycle tracking, auto-generated invoice PDF, referral balance, voucher rules.' },
  { n: '04', name: 'Deliver',   outcome: 'Check attendees in on a phone. Certificates send themselves.',                       mechanic: 'QR check-in, per-session attendance, auto-generated certificates from .docx templates.' },
  { n: '05', name: 'Follow-up', outcome: 'Thank-yous, surveys, and recordings go out without you lifting a finger.',           mechanic: 'Scheduled post-event email, NPS surveys, gated recording access, Excel P&L export.' },
  { n: '06', name: 'Retain',    outcome: 'Turn attendees into members.',                                                       mechanic: 'Monthly subscription plans, loyalty credits on check-in, auto customer segmentation, re-engagement campaigns.' },
];

const howSteps = [
  { n: '01', title: 'Build your event.',     body: 'Start from a template or from scratch. Set sessions, pricing tiers, add-ons, and a landing page.' },
  { n: '02', title: 'Share and sell.',       body: 'One link handles registration, payment, vouchers, and reminders.' },
  { n: '03', title: 'Run it and follow up.', body: 'QR check-in on the day. Certificates, feedback, and the next-event invite go out automatically.' },
];

const replacements = [
  { job: 'Event landing page',                before: '[form-tool-1], link-in-bio, site builders',    after: 'Per-event landing page with SEO settings' },
  { job: 'Registration form',                 before: '[form-tool-2], [form-tool-3]',                 after: 'Built-in order flow with catalog plus add-ons' },
  { job: 'Payment collection',                before: 'Bank transfer via WhatsApp, QRIS screenshot', after: 'Bank transfer, QRIS, and card payments in one flow' },
  { job: 'Payment reconciliation',            before: 'Spreadsheet, bank app, manual cross-check',   after: 'Order lifecycle: pending, confirmed, completed' },
  { job: 'Invoices',                          before: 'Typed by hand in Word or Canva',              after: 'Auto-generated PDF' },
  { job: 'Vouchers and discount codes',       before: 'A note on your phone',                        after: 'Voucher rules with date ranges, limits, stackability' },
  { job: 'Referral tracking',                 before: 'Nothing, or a spreadsheet',                   after: 'Per-customer referral code and balance' },
  { job: 'Reminder emails',                   before: '[email-tool-1], WhatsApp broadcasts',         after: 'Scheduled D-3 and D-1 emails, in-app' },
  { job: 'Waitlist for sold-out events',      before: 'DMs in your inbox',                           after: 'Public waitlist with auto-notify on cancel' },
  { job: 'Attendee list on event day',        before: 'Printed spreadsheet, pen tick-marks',         after: 'QR check-in on phone' },
  { job: 'Per-session attendance',            before: 'A separate list for each day',                after: 'Session-level attendance tracking' },
  { job: 'Event materials',                   before: 'Drive link in a group chat',                  after: 'Materials tab, gated by check-in' },
  { job: 'Certificates',                      before: '[design-tool] template, edited by hand',      after: 'Auto-generated from .docx template' },
  { job: 'Thank-you email after the event',   before: 'Usually forgotten',                           after: 'Scheduled post-event email' },
  { job: 'Feedback and NPS',                  before: '[form-tool-4] link',                          after: 'Built-in survey with NPS gauge' },
  { job: 'Recording and replay access',       before: 'Unlisted video link in a group chat',         after: 'Embedded video with availability window' },
  { job: 'Financial reports',                 before: 'Spreadsheet with manual entries',             after: 'Excel P&L export per event' },
  { job: 'Customer list',                     before: 'Phone contacts plus a spreadsheet',           after: 'Customer database with auto-tags' },
  { job: 'Membership and recurring revenue',  before: 'Not done, or a Google Sheet',                 after: 'Monthly subscription plans with feature gating' },
  { job: 'Loyalty for repeat attendees',      before: 'Not done',                                    after: 'Credit on check-in, usable on next order' },
  { job: 'Re-engagement of lapsed customers', before: 'Not done',                                    after: 'Tag-based campaign with preview count' },
];

const messyTiles = [
  { t: 'form tool',     r: '-4deg',  x: '6%',  y: '8%'  },
  { t: 'link-in-bio',   r: '3deg',   x: '40%', y: '3%'  },
  { t: 'spreadsheet',   r: '-2deg',  x: '70%', y: '12%' },
  { t: 'email tool',    r: '5deg',   x: '12%', y: '36%' },
  { t: 'WhatsApp',      r: '-3deg',  x: '46%', y: '30%' },
  { t: 'design tool',   r: '2deg',   x: '74%', y: '42%' },
  { t: 'bank app',      r: '-5deg',  x: '4%',  y: '62%' },
  { t: 'Drive link',    r: '4deg',   x: '34%', y: '58%' },
  { t: 'survey tool',   r: '-1deg',  x: '64%', y: '68%' },
  { t: 'video host',    r: '3deg',   x: '20%', y: '84%' },
  { t: 'another sheet', r: '-4deg',  x: '56%', y: '86%' },
];

const builtFor = ['Yoga studios', 'Workshop hosts', 'Training providers', 'Small conference organizers'];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Acara · Event Management for Yoga Studios, Workshops, and Training Providers</title>
    <meta name="description" content="One platform for the full event lifecycle. Plan, sell, check in, follow up, and retain. Built for businesses that run events every week." />
  </head>
  <body class="paper-grain min-h-screen antialiased bg-paper text-ink">

    <!-- Header -->
    <header class="border-b border-rule">
      <div class="mx-auto flex max-w-7xl items-center justify-between px-6 md:px-12 h-16">
        <a href="/" class="font-display text-2xl tracking-tight inline-flex items-center h-11">
          Acara<span class="text-accent-ink">.</span>
        </a>
        <nav class="hidden md:flex items-center gap-6">
          <a href="#lifecycle" class="label inline-flex items-center h-11 px-2 hover:text-ink">Lifecycle</a>
          <a href="#how"       class="label inline-flex items-center h-11 px-2 hover:text-ink">How it works</a>
          <a href="#replace"   class="label inline-flex items-center h-11 px-2 hover:text-ink">Replaces</a>
          <a href="#pricing"   class="label inline-flex items-center h-11 px-2 hover:text-ink">Pricing</a>
        </nav>
        <MotionCta href={TALLY_URL} label="Get started" variant="ink" size="md" client:load />
      </div>
    </header>

    <!-- Fold 1 · Hero -->
    <section class="border-b border-rule">
      <div class="mx-auto max-w-3xl px-6 md:px-12 pt-20 md:pt-32 pb-16 md:pb-24 text-center">
        <div class="label mb-12 flex flex-wrap items-center justify-center gap-4">
          <span>01 / 05</span>
          <span class="inline-block h-px w-12 bg-ink opacity-30"></span>
          <span>For operators who ship an event every week</span>
        </div>

        <h1 class="font-display text-5xl md:text-7xl lg:text-8xl leading-[1.05] tracking-tight">
          <span class="rise block" style="animation-delay: 0ms">Honestly, you just want your events to</span>
          <span class="rise block" style="animation-delay: 140ms"><span class="mark">sell out</span> without losing Sunday night</span>
          <span class="rise block italic text-accent-ink" style="animation-delay: 280ms">to a spreadsheet, right?</span>
        </h1>

        <p class="rise mt-12 text-lg md:text-xl leading-relaxed text-ink-muted" style="animation-delay: 500ms">
          Every operator running events every week hits the same wall&hellip;
        </p>

        <blockquote class="rise mt-6 font-display text-2xl md:text-3xl leading-snug" style="animation-delay: 620ms">
          &ldquo;How do you actually run a sold-out workshop &mdash; landing page, payment, QR check-in, certificates &mdash; <span class="italic text-accent-ink">without 11 browser tabs open?</span>&rdquo;
        </blockquote>

        <div class="rise mx-auto mt-14 h-px w-24 bg-ink opacity-30" style="animation-delay: 760ms"></div>

        <p class="rise mt-14 text-lg md:text-xl leading-relaxed" style="animation-delay: 820ms">
          So you can finally ship events without the glue work. There are <span class="num">3</span> things you&#39;ll do:
        </p>

        <ol class="rise mx-auto mt-8 max-w-md text-left space-y-3 text-base md:text-lg" style="animation-delay: 900ms">
          <li class="flex items-baseline gap-4">
            <span class="num text-sm text-ink-muted">1.</span>
            <span class="flex-1">Set up your event</span>
            <span class="num text-xs"><span class="mark">~10 MIN</span></span>
          </li>
          <li class="flex items-baseline gap-4">
            <span class="num text-sm text-ink-muted">2.</span>
            <span class="flex-1">Share one link</span>
            <span class="num text-xs text-ink-muted">PAGE, PAYMENT, REMINDERS</span>
          </li>
          <li class="flex items-baseline gap-4">
            <span class="num text-sm text-ink-muted">3.</span>
            <span class="flex-1">Run the day</span>
            <span class="num text-xs text-accent-ink">QR CHECK-IN &middot; CERTS</span>
          </li>
        </ol>

        <div class="rise mt-14 flex flex-wrap items-center justify-center gap-6" style="animation-delay: 1000ms">
          <MotionCta href={TALLY_URL} label="Get started" variant="ink" size="lg" client:load />
          <a href="#how" class="label inline-flex items-center h-11 px-1 underline underline-offset-4 decoration-ink decoration-1 hover:text-accent-ink hover:decoration-accent-ink">
            See how it works
          </a>
        </div>

        <p class="rise mt-10 text-sm text-ink-muted" style="animation-delay: 1100ms">
          Six stages: {stages.map((s) => s.name).join(' · ')}.
        </p>

        <p class="rise mt-3 text-sm text-ink-muted" style="animation-delay: 1180ms">
          Built for {builtFor.join(' · ')}.
        </p>
      </div>
    </section>

    <!-- Fold 2 · Lifecycle -->
    <section id="lifecycle" class="border-b border-rule">
      <div class="mx-auto max-w-3xl px-6 md:px-12 py-20 md:py-28 text-center">
        <div class="label mb-10">02 / 05 · The lifecycle</div>
        <h2 class="font-display text-5xl md:text-7xl leading-[1.05] tracking-tight">
          One system for <span class="italic text-accent-ink">every stage</span> of your event.
        </h2>
        <p class="mt-8 text-lg text-ink-muted">
          Six stages. One login. No glue code, no spreadsheets, no tab-switching.
        </p>
      </div>

      <div class="mx-auto max-w-5xl px-6 md:px-12 pb-20 md:pb-28">
        <div class="grid md:grid-cols-3 grid-rows-2 border-t border-l border-rule">
          {stages.map((s, i) => (
            <article class="reveal border-r border-b border-rule p-8 md:p-10 bg-paper hover:bg-ink hover:text-paper transition-colors group text-center" style={`--reveal-delay: ${i * 90}ms`}>
              <div class="flex items-baseline justify-center gap-3">
                <span class="num text-xs text-ink-muted group-hover:text-paper/60">{s.n}</span>
                <span class="label group-hover:text-paper/60">stage</span>
              </div>
              <h3 class="mt-5 font-display text-3xl md:text-4xl">{s.name}</h3>
              <p class="mt-5 text-base leading-relaxed">{s.outcome}</p>
              <div class="mt-6 pt-5 border-t border-rule group-hover:border-paper/20">
                <div class="label group-hover:text-paper/60">Mechanics</div>
                <p class="mt-3 text-sm leading-relaxed text-ink-muted group-hover:text-paper/80">{s.mechanic}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- Fold 3 · How it works -->
    <section id="how" class="border-b border-rule">
      <div class="mx-auto max-w-3xl px-6 md:px-12 py-20 md:py-28 text-center">
        <div class="label mb-10">03 / 05 · How it works</div>
        <h2 class="font-display text-5xl md:text-7xl leading-[1.05] tracking-tight">
          Three steps from <span class="italic text-accent-ink">idea</span> to sold-out.
        </h2>

        <div class="mt-16 space-y-12">
          {howSteps.map((step, i) => (
            <div
              style={`--reveal-delay: ${i * 120}ms`}
              class="reveal"
            >
              <div class="font-display text-7xl md:text-8xl text-accent-ink leading-none">{step.n}</div>
              <h3 class="mt-4 font-display text-2xl md:text-3xl">{step.title}</h3>
              <p class="mx-auto mt-4 max-w-xl text-base md:text-lg leading-relaxed text-ink-muted">{step.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Fold 4 · Replaces -->
    <section id="replace" class="border-b border-rule bg-ink text-on-ink">
      <div class="mx-auto max-w-3xl px-6 md:px-12 py-20 md:py-28 text-center">
        <div class="label mb-10 text-on-ink-subtle">04 / 05 · Replaces</div>
        <h2 class="font-display text-5xl md:text-7xl leading-[1.05] tracking-tight">
          The tool stack you&#39;re running today. <span class="italic text-ember">And what replaces it.</span>
        </h2>
        <p class="mt-8 text-lg md:text-xl leading-relaxed text-on-ink-muted">
          Most recurring-event operators are quietly running 8 to 12 tools, paying for half of them, and holding the rest together with WhatsApp and a spreadsheet.
        </p>
      </div>

      <div class="mx-auto max-w-5xl px-6 md:px-12 pb-20 md:pb-28">
        <div class="grid md:grid-cols-2 gap-10 md:gap-16 items-start">
          <!-- messy before -->
          <div class="relative h-[28rem] md:h-[32rem] border border-on-ink/15">
            <div class="absolute top-3 left-3 label text-on-ink-subtle">Before</div>
            <div class="absolute top-3 right-3 num text-xs text-on-ink-subtle">11 tabs open</div>
            <svg class="absolute inset-0 w-full h-full" preserveAspectRatio="none" viewBox="0 0 100 100">
              <g stroke="currentColor" class="text-on-ink/15" stroke-width="0.15" stroke-dasharray="0.6 0.8" fill="none">
                <path d="M10 14 L44 10 L74 18 L16 42 L50 36 L78 48 L8 68 L38 64 L68 74 L24 90 L60 92"/>
                <path d="M44 10 L16 42 M50 36 L8 68 M78 48 L38 64 M60 92 L24 90"/>
              </g>
            </svg>
            {messyTiles.map((tile, i) => (
              <div
                class="settle absolute px-3 py-2 text-xs num border border-on-ink/35 bg-ink text-on-ink/80"
                style={`left: ${tile.x}; top: ${tile.y}; --r: ${tile.r}; transform: rotate(${tile.r}); --reveal-delay: ${i * 70}ms`}
              >
                {tile.t}
              </div>
            ))}
          </div>

          <!-- after card -->
          <div class="relative p-8 md:p-10 border-2 border-ember text-center">
            <div class="absolute -top-3 left-1/2 -translate-x-1/2 px-3 label bg-ink text-ember">After</div>
            <div class="font-display text-5xl md:text-6xl">One login.</div>
            <div class="mt-2 num text-xs text-on-ink-subtle">acara.app</div>
            <ul class="mt-8 space-y-3 text-base text-left">
              {stages.map((s) => (
                <li class="flex items-center gap-4">
                  <span class="num text-xs text-ember">{s.n}</span>
                  <span>{s.name}</span>
                  <span class="flex-1 border-b border-on-ink/15"></span>
                  <span class="label text-on-ink-subtle">built-in</span>
                </li>
              ))}
            </ul>
            <p class="mt-10 text-sm text-on-ink-muted">
              That adds up to 15 tools, three subscriptions, and a lot of tab-switching. Acara is one login.
            </p>
          </div>
        </div>

        <div class="mt-20 text-center">
          <div class="label mb-6 text-on-ink-subtle">Full replacement map</div>
          <ReplacementMap rows={replacements} client:visible />
        </div>
      </div>
    </section>

    <!-- Fold 5 · Pricing, FAQ, CTA -->
    <section id="pricing" class="border-b border-rule">
      <div class="mx-auto max-w-3xl px-6 md:px-12 py-20 md:py-28 text-center">
        <div class="label mb-10">05 / 05 · Pricing &amp; questions</div>

        <h2 class="font-display text-5xl md:text-6xl leading-[1.05] tracking-tight">
          One plan. <span class="italic text-accent-ink">One price.</span>
        </h2>

        <div class="mt-10 mx-auto max-w-md border-2 border-ink p-8 text-left">
          <div class="label text-center">Annual</div>
          <div class="mt-3 flex items-baseline justify-center gap-2">
            <span class="font-display text-7xl md:text-8xl leading-none">$200</span>
            <span class="num text-sm text-ink-muted">/ year</span>
          </div>
          <div class="mt-3 text-ink-muted text-center">No per-attendee fees. No tiers.</div>
          <Separator className="my-7 bg-ink opacity-20" />
          <ul class="space-y-3 text-base">
            <li class="flex gap-3"><span class="num text-accent-ink">+</span> Unlimited events</li>
            <li class="flex gap-3"><span class="num text-accent-ink">+</span> Unlimited attendees</li>
            <li class="flex gap-3"><span class="num text-accent-ink">+</span> Unlimited emails from the platform</li>
            <li class="flex gap-3"><span class="num text-accent-ink">+</span> Every module in the lifecycle band</li>
            <li class="flex gap-3"><span class="num text-accent-ink">+</span> Full data export, anytime</li>
          </ul>
          <div class="mt-8">
            <MotionCta href={TALLY_URL} label="Get started" variant="ink" size="lg" fullWidth client:load />
          </div>
        </div>

        <div class="mt-24 pt-16 border-t border-rule text-left">
          <div class="label mb-6 text-center">The hard questions</div>
          <Faq client:load />
        </div>
      </div>
    </section>

    <!-- Final CTA -->
    <section class="border-b border-rule bg-ink text-on-ink">
      <div class="mx-auto max-w-7xl px-6 md:px-12 py-24 md:py-36 text-center">
        <h2 class="font-display text-5xl md:text-7xl leading-tight tracking-tight max-w-4xl mx-auto">
          Stop running your business <span class="italic text-ember">across 12 tools.</span>
        </h2>
        <p class="mt-8 max-w-xl mx-auto text-lg text-on-ink-muted">
          One login. One price. Every stage of your event, handled.
        </p>
        <div class="mt-10 inline-flex">
          <MotionCta href={TALLY_URL} label="Get started" variant="paper" size="lg" client:load />
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer>
      <div class="mx-auto max-w-3xl px-6 md:px-12 py-10 flex flex-col items-center gap-4 text-center">
        <div class="font-display text-xl">Acara<span class="text-accent-ink">.</span></div>
        <div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2">
          <a href={TALLY_URL}                    class="label inline-flex items-center h-11 px-2 hover:text-ink">Get started</a>
          <a href="mailto:ilzammulkhaq85@gmail.com" class="label inline-flex items-center h-11 px-2 hover:text-ink">ilzammulkhaq85@gmail.com</a>
          <a href="https://ilzam.dev/" class="label inline-flex items-center h-11 px-2 hover:text-ink">ilzam.dev</a>
          <span class="num text-xs text-ink-muted inline-flex items-center h-11 px-2">© 2026 Acara</span>
        </div>
      </div>
    </footer>

    <script is:inline>
      (() => {
        const els = document.querySelectorAll('.reveal, .settle');
        if (!('IntersectionObserver' in window) || window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          els.forEach((el) => el.classList.add('is-in'));
          return;
        }
        const io = new IntersectionObserver((entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              e.target.classList.add('is-in');
              io.unobserve(e.target);
            }
          }
        }, { rootMargin: '0px 0px -8% 0px', threshold: 0.12 });
        els.forEach((el) => io.observe(el));
      })();
    </script>
  </body>
</html>
